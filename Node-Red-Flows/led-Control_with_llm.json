    {
        "id": "bfa342232541ee30",
        "type": "function",
        "z": "9ba695f0fd5c6ac5",
        "name": "Parse Nvidia response",
        "func": "let response = msg.payload;\n\n// NVIDIA/OpenAI style\nlet content = response.choices[0].message.content;\n\n// Sometimes LLM adds extra text → clean it\nlet jsonStart = content.indexOf(\"{\");\nlet jsonEnd = content.lastIndexOf(\"}\");\n\nlet cleanJson = content.substring(jsonStart, jsonEnd + 1);\n\nlet data = JSON.parse(cleanJson);\n\n// Convert to final command\nif (data.intent === \"device_control\") {\n    if (data.action === \"on\") {\n        msg.payload = \"LED_ON\";\n    } else {\n        msg.payload = \"LED_OFF\";\n    }\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 920,
        "y": 300,
