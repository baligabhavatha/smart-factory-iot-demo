    {
        "id": "e7512bec8e73212e",
        "type": "function",
        "z": "9ba695f0fd5c6ac5",
        "name": "Parse telegram content",
        "func": "let userText = msg.payload.content;\n\nmsg.headers = {\n    \"Authorization\": \"Bearer YOUR_API_KEY\",\n    \"Content-Type\": \"application/json\"\n};\n\nmsg.payload = {\n    model: \"google/gemma-4-31b-it\",\n    messages: [\n        {\n            role: \"user\",\n            content: `\nExtract intent from this message.\n\nReturn ONLY JSON:\n{\n  \"intent\": \"device_control\",\n  \"device\": \"light\",\n  \"action\": \"on/off\"\n}\n\nMessage: \"${userText}\"\n`\n        }\n    ]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
